# Universal AI Autofill Assistant — Environment Configuration Template
# Duplicate this file to '.env' in the project root if modifying environment variables.
# Note: The core application is entirely offline-first. These flags are for developers.

# Build Configuration
DEBUG_LOGS_ENABLED=true
DEVELOPER_MODE_OVERRIDE=false

# Feature Flags
BYPASS_BIOMETRIC_ON_EMULATOR=false
OCR_HINDI_LANGUAGE_SUPPORT=false
WEBVIEW_INJECTION_EXPERIMENTAL=false

# Local Development Settings
ADB_DEVICE_PORT=5037
MOCK_CAMERA_FEED=false
